# Server
PORT=8080

# Default model (used when no model is passed in the request)
DOCGEN_MODEL=gpt-4o

# API Keys — fill in the ones you use, leave the rest blank
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# Set to 1 to use the offline FakeLLM (no API key needed)
DOCGEN_FAKE=0
